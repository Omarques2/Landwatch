            "text": "const memoryCache = /* @__PURE__ */ new Map();\nconst CACHE_PREFIX = \"analysis-map:v6:\";\nconst DEFAULT_TTL_MS = 24 * 60 * 60 * 1e3;\nfunction storageAvailable() {\n  try {\n    const testKey = `${CACHE_PREFIX}__test__`;\n    window.sessionStorage.setItem(testKey, \"1\");\n    window.sessionStorage.removeItem(testKey);\n    return true;\n  } catch {\n    return false;\n  }\n}\nexport function getAnalysisMapCache(id, tolerance, ttlMs = DEFAULT_TTL_MS) {\n  const key = `${CACHE_PREFIX}${id}:${tolerance ?? \"default\"}`;\n  const now = Date.now();\n  const memory = memoryCache.get(key);\n  if (memory && now - memory.storedAt <= ttlMs) {\n    return memory.value;\n  }\n  if (typeof window === \"undefined\" || !storageAvailable()) return null;\n  const raw = window.sessionStorage.getItem(key);\n  if (!raw) return null;\n  try {\n    const parsed = JSON.parse(raw);\n    if (!parsed || typeof parsed !== \"object\") return null;\n    if (now - parsed.storedAt > ttlMs) {\n      window.sessionStorage.removeItem(key);\n      return null;\n    }\n    memoryCache.set(key, parsed);\n    return parsed.value;\n  } catch {\n    return null;\n  }\n}\nexport function setAnalysisMapCache(id, tolerance, value) {\n  const key = `${CACHE_PREFIX}${id}:${tolerance ?? \"default\"}`;\n  const entry = { value, storedAt: Date.now() };\n  memoryCache.set(key, entry);\n  if (typeof window === \"undefined\" || !storageAvailable()) return;\n  try {\n    window.sessionStorage.setItem(key, JSON.stringify(entry));\n  } catch {\n  }\n}\nexport function clearAnalysisMapCache(id, tolerance) {\n  if (!id) {\n    memoryCache.clear();\n    if (typeof window === \"undefined\" || !storageAvailable()) return;\n    try {\n      const keys = Object.keys(window.sessionStorage);\n      for (const key2 of keys) {\n        if (key2.startsWith(CACHE_PREFIX)) {\n          window.sessionStorage.removeItem(key2);\n        }\n      }\n    } catch {\n    }\n    return;\n  }\n  const key = `${CACHE_P