            "text": "const PT_BR_LOCALE = \"pt-BR\";\nfunction titleCaseSegment(segment) {\n  if (!segment) return \"\";\n  const lower = segment.toLocaleLowerCase(PT_BR_LOCALE);\n  const chars = Array.from(lower);\n  const first = chars[0];\n  if (!first) return \"\";\n  const rest = chars.slice(1).join(\"\");\n  return `${first.toLocaleUpperCase(PT_BR_LOCALE)}${rest}`;\n}\nexport function toTitleCase(value) {\n  if (value === null || value === void 0) return \"\";\n  const raw = String(value).trim();\n  if (!raw) return \"\";\n  const normalized = raw.replace(/\\s+/g, \" \");\n  return normalized.split(\" \").map(\n    (token) => token.split(\"-\").map((segment) => titleCaseSegment(segment)).join(\"-\")\n  ).join(\" \");\n}\n\n//# sourceMappingURL=data:application/json;base64,"
