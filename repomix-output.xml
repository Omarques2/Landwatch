  LANDWATCH_CAR_MAP_SEARCH_TTL_MINUTES: numberSchema.default(30),

  LANDWATCH_PDF_STORAGE_DIR: z.string().optional(),
  LANDWATCH_PDF_TTL_HOURS: numberSchema.default(2),
