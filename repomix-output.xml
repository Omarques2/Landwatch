      <UiDialogFooter class="flex items-center justify-end gap-2 p-4">
        <UiButton variant="outline" :disabled="isSubmitting" @click="confirmMissingOpen = false">
          Voltar
        </UiButton>
        <UiButton :disabled="isSubmitting" @click="confirmMissingAndSubmit">
          Continuar
        </UiButton>
      </UiDialogFooter>
    </UiDialog>
