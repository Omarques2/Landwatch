@import "tailwindcss";
@import "tw-animate-css";

/* Faz o dark: responder à classe .dark no <html> */
@variant dark (&:where(.dark, .dark *));

:root {
  --background: hsl(210 20% 98%);
  --foreground: hsl(222 47% 11%);
  --card: hsl(210 20% 98%);
  --card-foreground: hsl(222 47% 11%);
