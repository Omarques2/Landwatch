            v-if="userMenuOpen"
            class="absolute bottom-[calc(100%+8px)] z-30 rounded-2xl border border-border bg-card shadow-lg"
            :class="isCollapsedDesktop ? 'left-full ml-2 w-[240px]' : 'left-0 w-full'"
