            WHEN NULLIF(p.pack_json->>'Cnuc', '') IS NOT NULL THEN 'Cnuc'
            WHEN NULLIF(p.pack_json->>'id', '') IS NOT NULL THEN 'id'
            WHEN NULLIF(p.pack_json->>'objectid', '') IS NOT NULL THEN 'objectid'
