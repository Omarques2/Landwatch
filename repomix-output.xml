            NULLIF(p.pack_json->>'objectid', ''),
            NULLIF(p.pack_json->>'OBJECTID', '')
          ) AS natural_id,
          COALESCE(
            NULLIF(p.pack_json->>'nome_uc', ''),
            NULLIF(p.pack_json->>'nome', ''),
            NULLIF(p.pack_json->>'NOME', ''),
