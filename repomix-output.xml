        r.overlap_pct_of_sicar,
        ST_AsGeoJSON(
          ST_SimplifyPreserveTopology(g.geom, ${safeTolerance})
        ) AS geom
      FROM ${Prisma.raw('"app"."analysis_result"')} r
      JOIN ${Prisma.raw(`"${schema}"."lw_geom_store"`)} g
