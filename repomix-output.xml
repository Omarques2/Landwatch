      ])
      .mockResolvedValueOnce([
        {
          datasetCode: 'PRODES_2024',
          featureId: 10n,
          categoryCode: 'PRODES',
          isSicar: false,
        },
      ]);
    prisma.analysisAlert.create.mockResolvedValue({ id: 'alert-1' });

    const service = new AlertsService(prisma);
