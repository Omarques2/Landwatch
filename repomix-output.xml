  };

  beforeAll(async () => {
    process.env.NODE_ENV = 'test';
    process.env.DATABASE_URL = 'postgresql://user:pass@localhost:5432/test';
    process.env.SIGFARM_AUTH_ISSUER =
      process.env.SIGFARM_AUTH_ISSUER ??
