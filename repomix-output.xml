    expect(wrapper.text()).toContain("Fornecedor Sem CAR");
    expect(wrapper.text()).toContain("2 fornecedores");
  });

  it("highlights selected cell and copies selected value with Ctrl+C", async () => {
    mockGetByUrl((url) => {
      if (url === "/v1/fornecedores/summary") {
        return {
          data: {
            data: {
              totalFornecedores: 1,
