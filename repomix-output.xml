        artifacts = [
            DatasetArtifact(
                category="UCS",
                dataset_code="FED",
                files=[fed_path],
                snapshot_date="2026-04-09",
            ),
            DatasetArtifact(
                category="UCS",
                dataset_code="CNUC",
