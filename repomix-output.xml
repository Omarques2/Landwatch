      where: { id },
      select: {
        id: true,
        status: true,
        carKey: true,
        analysisDate: true,
        analysisKind: true,
      },
    });
    if (!analysis) {
      throw new BadRequestException({
        code: 'ANALYSIS_NOT_FOUND',
        message: 'Analysis not found',
      });
