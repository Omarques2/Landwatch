ion buildDocErrors(docs) {\n      return docs.map((doc) => {\n        const digits = sanitizeDoc(doc ?? \"\");\n        if (!digits) return \"\";\n        if (digits.length !== 11 && digits.length !== 14) {\n          return \"CPF/CNPJ incompleto\";\n        }\n        return isValidCpfCnpj(digits) ? \"\" : \"CPF/CNPJ inválido\";\n      });\n    }\n    const editDocErrors = computed(() => buildDocErrors(editForm.documents));\n    const hasEditDocError = computed(() => editDocErrors.value.some(Boolean));\n    function statusBadgeClass(status) {\n      if (status === \"completed\") return \"border-emerald-200 text-emerald-600\";\n      if (status === \"failed\") return \"border-red-200 text-red-600\";\n      return \"border-amber-200 text-amber-700\";\n    }\n    function statusLabel(status) {\n      if (status === \"completed\") return \"Concluída\";\n      if (status === \"failed\") return \"Falhou\";\n      if (status === \"running\") return \"Em andamento\";\n      if (status === \"pending\") return \"Pendente\";\n      return status;\n    }\n    function formatDate(value) {\n      if (!value) return \"-\";\n      return value.slice(0, 10);\n    }\n    function maskCarKey(value) {\n      const cleaned = value.toUpperCase().replace(/[^A-Z0-9]/g, \"\").slice(0, 41);\n      const uf = cleaned.slice(0, 2);\n      const mid = cleaned.slice(2, 9);\n      const tail = cleaned.slice(9);\n      let out = uf;\n      if (mid) out += `-${mid}`;\n      if (tail) out += `-${tail}`;\n      return out;\n    }\n    function maskCpfCnpj(value) {\n      const digits = value.replace(/\\D/g, \"\").slice(0, 14);\n      if (digits.length <= 11) {\n        const p12 = digits.slice(0, 3);\n        const p22 = digits.slice(3, 6);\n        const p32 = digits.slice(6, 9);\n        const p42 = digits.slice(9, 11);\n        let out2 = p12;\n        if (p22) out2 += `.${p22}`;\n        if (p32) out2 += `.${p32}`;\n        if (p42) out2 += `-${p42}`;\n        return out2;\n      }\n      const p1 = digits.slice(0, 2);\n      const p2 = digits.slice(2, 5);\n      const p3 = digits.slice(5, 8);\n      const p4 = digits.slice(8, 12);\n      const p5 = digits.slice(12, 14);\n      let out = p1;\n      if (p2) out += `.${p2}`;\n      if (p3) out += `.${p3}`;\n      if (p4) out += `/${p4}`;\n      if (p5) out += `-${p5}`;\n      return out;\n    }\n    function onEditCarInput(value) {\n      editForm.carKey = maskCarKey(value ?? \"\");\n    }\n    function onEditDocInput(index, value) {\n      editForm.documents[index] = maskCpfCnpj(value ?? \"\");\n    }\n    function addEditDoc() {\n      editForm.documents.push(\"\");\n    }\n    function removeEditDoc(index) {\n      editForm.documents.splice(index, 1);\n    }\n    function formatDoc(doc) {\n      return maskCpfCnpj(doc ?? \"\");\n    }\n    async function loadFarm() {\n      loadingFarm.value = true;\n      farmError.value = \"\";\n      try {\n        const res = await http.get(`/v1/farms/${farmId}`);\n        farm.value = unwrapData(res.data);\n        editForm.name = farm.value?.name ?? \"\";\n        editForm.carKey = farm.value?.carKey ?? \"\";\n        editForm.documents = farm.value?.documents?.map((doc) => maskCpfCnpj(doc.docNormalized)) ?? [];\n        if (!mvBusy.value) {\n          void loadGeometry(farm.value?.carKey ?? \"\");\n        } else {\n          loadingGeom.value = false;\n          geomError.value = \"Base geoespacial em atualização.\";\n        }\n      } catch (err) {\n        farmError.value = err?.response?.data?.error?.message ?? err?.response?.data?.message ?? \"Falha ao carregar a fazenda.\";\n        farmGeom.value = null;\n        geomError.value = \"\";\n        loadingGeom.value = false;\n      } finally {\n        loadingFarm.value = false;\n      }\n    }\n    async function loadAnalyses() {\n      loadingAnalyses.value = true;\n      analysisError.value = \"\";\n      try {\n        const res = await http.get(\"/v1/analyses\", {\n          params: { farmId }\n        });