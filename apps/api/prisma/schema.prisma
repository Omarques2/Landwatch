generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["app"]
}

model User {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identityUserId String?    @unique @map("identity_user_id") @db.Uuid
  entraSub       String     @unique @map("entra_sub")
  entraOid       String?    @unique @map("entra_oid") @db.Uuid
  email          String?    @map("email")
  displayName    String?    @map("display_name")
  status         UserStatus @default(active)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  lastLoginAt    DateTime?  @map("last_login_at") @db.Timestamptz(6)

  memberships                 OrgMembership[]
  groupMemberships            OrgGroupMembership[]
  farms                       Farm[]
  analyses                    Analysis[]                  @relation("UserAnalyses")
  schedules                   AnalysisSchedule[]          @relation("UserSchedules")
  orgPermissions              OrgUserPermission[]         @relation("OrgUserPermissionUser")
  orgPermissionsGranted       OrgUserPermission[]         @relation("OrgUserPermissionGrantedBy")
  attachmentCategoriesCreated AttachmentCategory[]        @relation("AttachmentCategoryCreatedBy")
  attachmentsCreated          Attachment[]                @relation("AttachmentCreatedBy")
  attachmentsDeleted          Attachment[]                @relation("AttachmentDeletedBy")
  attachmentsRevoked          Attachment[]                @relation("AttachmentRevokedBy")
  attachmentTargetsCreated    AttachmentTarget[]          @relation("AttachmentTargetCreatedBy")
  attachmentTargetsReviewed   AttachmentTarget[]          @relation("AttachmentTargetReviewedBy")
  attachmentEvents            AttachmentEvent[]           @relation("AttachmentEventActorUser")
  attachmentMapFilterSessions AttachmentMapFilterSession[] @relation("AttachmentMapFilterSessionUser")
  carMapSearchSessions       CarMapSearchSession[]        @relation("CarMapSearchSessionUser")

  @@index([email], map: "idx_app_user_email")
  @@map("app_user")
  @@schema("app")
}

enum UserStatus {
  pending
  active
  disabled

  @@map("user_status")
  @@schema("app")
}

model Org {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String    @unique
  status    OrgStatus @default(active)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  memberships                    OrgMembership[]
  groups                         OrgGroup[]
  apiClients                     ApiClient[]
  farms                          Farm[]
  analyses                       Analysis[]
  orgUserPermissions             OrgUserPermission[]
  ownedAttachments               Attachment[]                  @relation("AttachmentOwnerOrg")
  attachmentTargets              AttachmentTarget[]            @relation("AttachmentTargetAppliesOrg")
  attachmentEvents               AttachmentEvent[]             @relation("AttachmentEventActorOrg")
  analysisAttachmentEffectiveOrg AnalysisAttachmentEffective[] @relation("AnalysisAttachmentEffectiveCapturedOrg")
  attachmentMapFilterSessions    AttachmentMapFilterSession[]  @relation("AttachmentMapFilterSessionOrg")

  @@map("org")
  @@schema("app")
}

model OrgMembership {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      OrgRole  @default(member)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId], map: "org_membership_org_user_key")
  @@map("org_membership")
  @@schema("app")
}

model OrgGroup {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org         Org                  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  memberships OrgGroupMembership[]

  @@unique([orgId, name], map: "org_group_org_name_key")
  @@map("org_group")
  @@schema("app")
}

model OrgGroupMembership {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId   String    @map("group_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      GroupRole @default(member)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  group OrgGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId], map: "org_group_membership_group_user_key")
  @@map("org_group_membership")
  @@schema("app")
}

model ApiClient {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  orgId     String?         @map("org_id") @db.Uuid
  status    ApiClientStatus @default(active)
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  org  Org?     @relation(fields: [orgId], references: [id], onDelete: SetNull)
  keys ApiKey[]

  @@map("api_client")
  @@schema("app")
}

model ApiKey {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId   String        @map("client_id") @db.Uuid
  keyPrefix  String        @map("key_prefix")
  keyHash    String        @unique @map("key_hash")
  scopes     ApiKeyScope[]
  expiresAt  DateTime?     @map("expires_at") @db.Timestamptz(6)
  lastUsedAt DateTime?     @map("last_used_at") @db.Timestamptz(6)
  revokedAt  DateTime?     @map("revoked_at") @db.Timestamptz(6)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  client ApiClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId], map: "api_key_client_id_idx")
  @@index([keyPrefix], map: "api_key_prefix_idx")
  @@map("api_key")
  @@schema("app")
}

model Farm {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  carKey      String   @map("car_key")
  ownerUserId String   @map("owner_user_id") @db.Uuid
  orgId       String?  @map("org_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner     User               @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  org       Org?               @relation(fields: [orgId], references: [id], onDelete: SetNull)
  analyses  Analysis[]
  schedules AnalysisSchedule[]
  alerts    AnalysisAlert[]
  documents FarmDocument[]

  @@unique([carKey], map: "farm_car_key_key")
  @@index([ownerUserId], map: "farm_owner_user_id_idx")
  @@index([orgId], map: "farm_org_id_idx")
  @@map("farm")
  @@schema("app")
}

enum FarmDocType {
  CPF
  CNPJ

  @@map("farm_doc_type")
  @@schema("app")
}

model FarmDocument {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmId        String      @map("farm_id") @db.Uuid
  docType       FarmDocType @map("doc_type")
  docNormalized String      @map("doc_normalized")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@unique([farmId, docNormalized], map: "farm_document_unique")
  @@index([docNormalized], map: "farm_document_doc_idx")
  @@index([farmId], map: "farm_document_farm_idx")
  @@map("farm_document")
  @@schema("app")
}

model Analysis {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  carKey            String             @map("car_key")
  analysisDocs      Json               @default("[]") @map("analysis_docs")
  analysisDate      DateTime           @map("analysis_date") @db.Date
  status            AnalysisStatus     @default(pending)
  createdByUserId   String             @map("created_by_user_id") @db.Uuid
  orgId             String?            @map("org_id") @db.Uuid
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  attachmentsSnapshotCutoffAt   DateTime? @map("attachments_snapshot_cutoff_at") @db.Timestamptz(6)
  attachmentsSnapshotCapturedAt DateTime? @map("attachments_snapshot_captured_at") @db.Timestamptz(6)
  completedAt       DateTime?          @map("completed_at") @db.Timestamptz(6)
  farmId            String?            @map("farm_id") @db.Uuid
  pdfStatus         AnalysisPdfStatus? @map("pdf_status")
  pdfPath           String?            @map("pdf_path")
  pdfGeneratedAt    DateTime?          @map("pdf_generated_at") @db.Timestamptz(6)
  pdfExpiresAt      DateTime?          @map("pdf_expires_at") @db.Timestamptz(6)
  pdfError          String?            @map("pdf_error")
  hasIntersections  Boolean            @default(false) @map("has_intersections")
  intersectionCount Int                @default(0) @map("intersection_count")
  analysisKind      AnalysisKind       @default(STANDARD) @map("analysis_kind")
  scheduleId        String?            @map("schedule_id") @db.Uuid

  results               AnalysisResult[]
  cache                 AnalysisCache?
  alerts                AnalysisAlert[]
  attachmentSnapshots   AnalysisAttachmentEffective[]
  postprocessJobs       AnalysisPostprocessJob[]
  createdBy             User                          @relation("UserAnalyses", fields: [createdByUserId], references: [id], onDelete: Restrict)
  org                   Org?                          @relation(fields: [orgId], references: [id], onDelete: SetNull)
  farm                  Farm?                         @relation(fields: [farmId], references: [id], onDelete: SetNull)
  schedule              AnalysisSchedule?             @relation("ScheduleAnalyses", fields: [scheduleId], references: [id], onDelete: SetNull)

  @@index([carKey], map: "analysis_car_key_idx")
  @@index([createdByUserId], map: "analysis_created_by_idx")
  @@index([farmId], map: "analysis_farm_id_idx")
  @@index([analysisKind], map: "analysis_kind_idx")
  @@index([scheduleId], map: "analysis_schedule_id_idx")
  @@index([status], map: "analysis_status_idx")
  @@index([pdfStatus], map: "analysis_pdf_status_idx")
  @@map("analysis")
  @@schema("app")
}

model AnalysisResult {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  analysisId        String    @map("analysis_id") @db.Uuid
  categoryCode      String    @map("category_code")
  datasetCode       String    @map("dataset_code")
  snapshotDate      DateTime? @map("snapshot_date") @db.Date
  featureId         BigInt?   @map("feature_id")
  geomId            BigInt?   @map("geom_id")
  isSicar           Boolean   @default(false) @map("is_sicar")
  sicarAreaM2       Decimal?  @map("sicar_area_m2")
  featureAreaM2     Decimal?  @map("feature_area_m2")
  overlapAreaM2     Decimal?  @map("overlap_area_m2")
  overlapPctOfSicar Decimal?  @map("overlap_pct_of_sicar")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId], map: "analysis_result_analysis_id_idx")
  @@index([analysisId, geomId], map: "analysis_result_analysis_geom_idx")
  @@index([analysisId, datasetCode, featureId], map: "analysis_result_analysis_dataset_feature_idx")
  @@index([categoryCode], map: "analysis_result_category_idx")
  @@map("analysis_result")
  @@schema("app")
}

enum AnalysisPostprocessJobType {
  CNPJ_REFRESH
  ALERTS_BUILD
  ATTACHMENTS_EFFECTIVE_CAPTURE
  ANALYSIS_CACHE_BUILD

  @@map("analysis_postprocess_job_type")
  @@schema("app")
}

enum AnalysisPostprocessJobStatus {
  PENDING
  RUNNING
  RETRY
  COMPLETED
  FAILED

  @@map("analysis_postprocess_job_status")
  @@schema("app")
}

model AnalysisPostprocessJob {
  id           String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobType      AnalysisPostprocessJobType  @map("job_type")
  analysisId   String?                      @map("analysis_id") @db.Uuid
  docNormalized String?                     @map("doc_normalized")
  dedupeKey    String?                      @map("dedupe_key")
  status       AnalysisPostprocessJobStatus @default(PENDING)
  attemptCount Int                          @default(0) @map("attempt_count")
  runAfter     DateTime                     @default(now()) @map("run_after") @db.Timestamptz(6)
  lockedAt     DateTime?                    @map("locked_at") @db.Timestamptz(6)
  lastError    String?                      @map("last_error")
  payload      Json                         @default("{}")
  createdAt    DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)

  analysis Analysis? @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([status, runAfter], map: "analysis_postprocess_job_status_run_after_idx")
  @@index([analysisId], map: "analysis_postprocess_job_analysis_id_idx")
  @@index([jobType], map: "analysis_postprocess_job_type_idx")
  @@map("analysis_postprocess_job")
  @@schema("app")
}

model AnalysisSchedule {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmId          String            @map("farm_id") @db.Uuid
  analysisKind    AnalysisKind      @map("analysis_kind")
  frequency       ScheduleFrequency
  nextRunAt       DateTime          @map("next_run_at") @db.Timestamptz(6)
  lastRunAt       DateTime?         @map("last_run_at") @db.Timestamptz(6)
  isActive        Boolean           @default(true) @map("is_active")
  timezone        String            @default("UTC")
  createdByUserId String            @map("created_by_user_id") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  farm      Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  createdBy User            @relation("UserSchedules", fields: [createdByUserId], references: [id], onDelete: Restrict)
  analyses  Analysis[]      @relation("ScheduleAnalyses")
  alerts    AnalysisAlert[]

  @@index([farmId], map: "analysis_schedule_farm_id_idx")
  @@index([isActive, nextRunAt], map: "analysis_schedule_due_idx")
  @@index([createdByUserId], map: "analysis_schedule_user_id_idx")
  @@map("analysis_schedule")
  @@schema("app")
}

model AnalysisAlert {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmId               String              @map("farm_id") @db.Uuid
  scheduleId           String              @map("schedule_id") @db.Uuid
  analysisId           String              @map("analysis_id") @db.Uuid
  analysisKind         AnalysisKind        @map("analysis_kind")
  alertType            AnalysisAlertType   @map("alert_type")
  newIntersectionCount Int                 @map("new_intersection_count")
  payload              Json                @default("{}")
  status               AnalysisAlertStatus @default(NEW)
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt           DateTime?           @map("resolved_at") @db.Timestamptz(6)

  farm     Farm             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  schedule AnalysisSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  analysis Analysis         @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([farmId], map: "analysis_alert_farm_id_idx")
  @@index([scheduleId], map: "analysis_alert_schedule_id_idx")
  @@index([analysisId], map: "analysis_alert_analysis_id_idx")
  @@index([status, createdAt], map: "analysis_alert_status_created_idx")
  @@map("analysis_alert")
  @@schema("app")
}

model AnalysisCache {
  analysisId String   @id @map("analysis_id") @db.Uuid
  payload    Json
  cachedAt   DateTime @default(now()) @map("cached_at") @db.Timestamptz(6)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([expiresAt], map: "analysis_cache_expires_idx")
  @@map("analysis_cache")
  @@schema("app")
}

model OrgUserPermission {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String        @map("org_id") @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  permission      OrgPermission
  grantedByUserId String        @map("granted_by_user_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  org           Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user          User @relation("OrgUserPermissionUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedByUser User @relation("OrgUserPermissionGrantedBy", fields: [grantedByUserId], references: [id], onDelete: Restrict)

  @@unique([orgId, userId, permission], map: "org_user_permission_org_user_permission_key")
  @@index([orgId, permission], map: "org_user_permission_org_idx")
  @@index([userId, permission], map: "org_user_permission_user_idx")
  @@map("org_user_permission")
  @@schema("app")
}

model AttachmentCategory {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String   @unique
  name             String
  description      String?
  isJustification  Boolean  @default(false) @map("is_justification")
  requiresApproval Boolean  @default(false) @map("requires_approval")
  isPublicDefault  Boolean  @default(true) @map("is_public_default")
  isActive         Boolean  @default(true) @map("is_active")
  createdByUserId  String   @map("created_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdByUser User         @relation("AttachmentCategoryCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  attachments   Attachment[]

  @@index([isActive], map: "attachment_category_active_idx")
  @@map("attachment_category")
  @@schema("app")
}

model Attachment {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId       String               @map("category_id") @db.Uuid
  ownerOrgId       String?              @map("owner_org_id") @db.Uuid
  createdByUserId  String               @map("created_by_user_id") @db.Uuid
  originalFilename String               @map("original_filename")
  contentType      String               @map("content_type")
  sizeBytes        BigInt               @map("size_bytes")
  sha256           String
  blobProvider     String               @default("AZURE_BLOB") @map("blob_provider")
  blobContainer    String               @map("blob_container")
  blobPath         String               @unique @map("blob_path")
  blobEtag         String?              @map("blob_etag")
  visibility       AttachmentVisibility @default(PUBLIC)
  status           AttachmentStatus     @default(PENDING)
  isDeletedLogical Boolean              @default(false) @map("is_deleted_logical")
  deletedAt        DateTime?            @map("deleted_at") @db.Timestamptz(6)
  deletedByUserId  String?              @map("deleted_by_user_id") @db.Uuid
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  submittedAt      DateTime             @default(now()) @map("submitted_at") @db.Timestamptz(6)
  revokedAt        DateTime?            @map("revoked_at") @db.Timestamptz(6)
  revokedByUserId  String?              @map("revoked_by_user_id") @db.Uuid

  category           AttachmentCategory            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  ownerOrg           Org?                          @relation("AttachmentOwnerOrg", fields: [ownerOrgId], references: [id], onDelete: SetNull)
  createdByUser      User                          @relation("AttachmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  deletedByUser      User?                         @relation("AttachmentDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  revokedByUser      User?                         @relation("AttachmentRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  targets            AttachmentTarget[]
  events             AttachmentEvent[]
  effectiveSnapshots AnalysisAttachmentEffective[]

  @@index([ownerOrgId, createdAt(sort: Desc)], map: "attachment_owner_org_idx")
  @@index([status], map: "attachment_status_idx")
  @@index([categoryId], map: "attachment_category_idx")
  @@map("attachment")
  @@schema("app")
}

model AttachmentTarget {
  id               String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attachmentId     String                 @map("attachment_id") @db.Uuid
  datasetCode      String                 @map("dataset_code")
  featureId        BigInt?                @map("feature_id")
  featureKey       String?                @map("feature_key")
  naturalId        String?                @map("natural_id")
  carKey           String?                @map("car_key")
  scope            AttachmentScope
  appliesOrgId     String?                @map("applies_org_id") @db.Uuid
  validFrom        DateTime               @map("valid_from") @db.Date
  validTo          DateTime?              @map("valid_to") @db.Date
  status           AttachmentTargetStatus @default(PENDING)
  reviewedByUserId String?                @map("reviewed_by_user_id") @db.Uuid
  reviewedAt       DateTime?              @map("reviewed_at") @db.Timestamptz(6)
  reviewReason     String?                @map("review_reason")
  createdByUserId  String                 @map("created_by_user_id") @db.Uuid
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  attachment         Attachment                    @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  appliesOrg         Org?                          @relation("AttachmentTargetAppliesOrg", fields: [appliesOrgId], references: [id], onDelete: SetNull)
  reviewedByUser     User?                         @relation("AttachmentTargetReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  createdByUser      User                          @relation("AttachmentTargetCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  events             AttachmentEvent[]
  effectiveSnapshots AnalysisAttachmentEffective[]

  @@index([attachmentId], map: "attachment_target_attachment_idx")
  @@index([datasetCode, featureId, featureKey, naturalId], map: "attachment_target_feature_lookup_idx")
  @@index([carKey], map: "attachment_target_car_idx")
  @@index([scope, appliesOrgId], map: "attachment_target_scope_org_idx")
  @@index([status, validFrom, validTo], map: "attachment_target_validity_idx")
  @@map("attachment_target")
  @@schema("app")
}

model AttachmentEvent {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attachmentId       String              @map("attachment_id") @db.Uuid
  attachmentTargetId String?             @map("attachment_target_id") @db.Uuid
  eventType          AttachmentEventType @map("event_type")
  actorUserId        String?             @map("actor_user_id") @db.Uuid
  actorOrgId         String?             @map("actor_org_id") @db.Uuid
  actorIp            String?             @map("actor_ip") @db.Inet
  payload            Json                @default("{}")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  attachment       Attachment        @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  attachmentTarget AttachmentTarget? @relation(fields: [attachmentTargetId], references: [id], onDelete: SetNull)
  actorUser        User?             @relation("AttachmentEventActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorOrg         Org?              @relation("AttachmentEventActorOrg", fields: [actorOrgId], references: [id], onDelete: SetNull)

  @@index([attachmentId, createdAt(sort: Desc)], map: "attachment_event_attachment_idx")
  @@index([attachmentTargetId, createdAt(sort: Desc)], map: "attachment_event_target_idx")
  @@map("attachment_event")
  @@schema("app")
}

model AttachmentMapFilterSession {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  filterHash      String   @map("filter_hash")
  filterVersion   Int      @default(1) @map("filter_version")
  scopeKey        String   @map("scope_key")
  actorUserId     String   @map("actor_user_id") @db.Uuid
  actorOrgId      String?  @map("actor_org_id") @db.Uuid
  isPlatformAdmin Boolean  @default(false) @map("is_platform_admin")
  filtersJson     Json     @map("filters_json")
  expiresAt       DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  actorUser User @relation("AttachmentMapFilterSessionUser", fields: [actorUserId], references: [id], onDelete: Cascade)
  actorOrg  Org? @relation("AttachmentMapFilterSessionOrg", fields: [actorOrgId], references: [id], onDelete: Cascade)

  @@index([filterHash, filterVersion, scopeKey], map: "attachment_map_filter_session_lookup_idx")
  @@index([expiresAt], map: "attachment_map_filter_session_expires_idx")
  @@index([actorUserId, createdAt(sort: Desc)], map: "attachment_map_filter_session_user_idx")
  @@map("attachment_map_filter_session")
  @@schema("app")
}

model CarMapSearchSession {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId    String   @map("actor_user_id") @db.Uuid
  searchVersion  Int      @default(1) @map("search_version")
  paramsJson     Json     @map("params_json")
  expiresAt      DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  actorUser User @relation("CarMapSearchSessionUser", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt(sort: Desc)], map: "car_map_search_session_user_idx")
  @@index([expiresAt], map: "car_map_search_session_expires_idx")
  @@map("car_map_search_session")
  @@schema("app")
}

model AnalysisAttachmentEffective {
  id                      String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  analysisId              String                 @map("analysis_id") @db.Uuid
  attachmentId            String                 @map("attachment_id") @db.Uuid
  attachmentTargetId      String                 @map("attachment_target_id") @db.Uuid
  datasetCode             String                 @map("dataset_code")
  featureId               BigInt?                @map("feature_id")
  featureKey              String?                @map("feature_key")
  naturalId               String?                @map("natural_id")
  carKey                  String?                @map("car_key")
  capturedScope           AttachmentScope        @map("captured_scope")
  capturedAppliesOrgId    String?                @map("captured_applies_org_id") @db.Uuid
  capturedVisibility      AttachmentVisibility   @map("captured_visibility")
  capturedTargetStatus    AttachmentTargetStatus @map("captured_target_status")
  capturedValidFrom       DateTime               @map("captured_valid_from") @db.Date
  capturedValidTo         DateTime?              @map("captured_valid_to") @db.Date
  capturedIsJustification Boolean                @map("captured_is_justification")
  capturedAt              DateTime               @default(now()) @map("captured_at") @db.Timestamptz(6)

  analysis           Analysis         @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  attachment         Attachment       @relation(fields: [attachmentId], references: [id], onDelete: Restrict)
  attachmentTarget   AttachmentTarget @relation(fields: [attachmentTargetId], references: [id], onDelete: Restrict)
  capturedAppliesOrg Org?             @relation("AnalysisAttachmentEffectiveCapturedOrg", fields: [capturedAppliesOrgId], references: [id], onDelete: SetNull)

  @@unique([analysisId, attachmentTargetId], map: "analysis_attachment_effective_analysis_target_key")
  @@index([analysisId], map: "analysis_attachment_effective_analysis_idx")
  @@index([datasetCode, featureId, featureKey, naturalId], map: "analysis_attachment_effective_feature_idx")
  @@map("analysis_attachment_effective")
  @@schema("app")
}

