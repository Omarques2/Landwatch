# Base
NODE_ENV=development
PORT=3001

# Database (app schema)
DATABASE_URL=postgresql://user:password@host:5432/landwatch?schema=app&sslmode=require
SHADOW_DATABASE_URL=postgresql://user:password@host:5432/landwatch_shadow?schema=app&sslmode=require

# Sigfarm Auth (JWT validation)
SIGFARM_AUTH_ISSUER=https://auth.sigfarmintelligence.com
SIGFARM_AUTH_AUDIENCE=sigfarm-apps
SIGFARM_AUTH_JWKS_URL=https://api-auth.sigfarmintelligence.com/.well-known/jwks.json

# Legacy Entra vars (deprecated)
ENTRA_API_AUDIENCE=
ENTRA_AUTHORITY_HOST=login.microsoftonline.com
ENTRA_JWKS_TENANT=common
PLATFORM_ADMIN_SUBS=

# Hardening
CORS_ORIGINS=http://localhost:5173
CORS_CREDENTIALS=false
ENABLE_CSP=false
CSP_FRAME_SRC=
CSP_CONNECT_SRC=
RATE_LIMIT_ADMIN_WINDOW_MS=60000
RATE_LIMIT_ADMIN_MAX=60
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX=120
RATE_LIMIT_TILES_WINDOW_MS=60000
RATE_LIMIT_TILES_MAX=3000
TRUST_PROXY=false
AUTH_BYPASS_LOCALHOST=false
DB_SSL_ALLOW_INVALID=false
API_KEY_PEPPER=change-me
API_KEY_PREFIX_LENGTH=8
DB_SCHEMA=app
LANDWATCH_SCHEMA=landwatch
LANDWATCH_SICAR_CATEGORY_CODE=SICAR
LANDWATCH_CAR_MAX_RADIUS_METERS=30000
LANDWATCH_CAR_MAX_RESULTS=25
LANDWATCH_CAR_MAP_SEARCH_MAX_RADIUS_METERS=50000
LANDWATCH_CAR_MAP_SEARCH_TTL_MINUTES=30
LANDWATCH_PDF_STORAGE_DIR=./storage/pdfs
LANDWATCH_PDF_TTL_HOURS=2
LANDWATCH_PDF_TILE_PROVIDERS=https://mt1.google.com/vt/lyrs=s&x={x}&y={y}&z={z}
ANALYSIS_STANDARD_CURRENT_USE_FAST_INTERSECTIONS=false
ANALYSIS_STANDARD_ASOF_USE_LEGACY_AREA=false
ATTACHMENTS_BLOB_ACCOUNT_URL=
ATTACHMENTS_BLOB_CONNECTION_STRING=
ATTACHMENTS_BLOB_CONTAINER=attachments
ATTACHMENTS_BLOB_PROVIDER=AZURE_BLOB
ATTACHMENTS_BLOB_CREDENTIAL_MODE=
ATTACHMENTS_LOCAL_DIR=./storage/attachments
ATTACHMENTS_SEARCH_SIMPLIFY_TOLERANCE_METERS=30
ATTACHMENTS_MVT_CACHE_MAX_AGE_SECONDS=1800
ATTACHMENTS_MVT_EXTENT=4096
ATTACHMENTS_MVT_VECTOR_MIN_ZOOM=3
ATTACHMENTS_MVT_VECTOR_MAX_ZOOM=12
ATTACHMENTS_MVT_MAP_MIN_ZOOM=1
ATTACHMENTS_MVT_MAP_MAX_ZOOM=20
ATTACHMENTS_MVT_CENTROID_MAX_ZOOM=10
ATTACHMENTS_MVT_CENTROID_SMALL_ONLY=true
ATTACHMENTS_MVT_CENTROID_SMALL_TILE_AREA=256
ATTACHMENTS_MVT_PREFETCH_MIN_ZOOM=9
ATTACHMENTS_MVT_PREFETCH_TARGET_ZOOM=11
ATTACHMENTS_MVT_PREFETCH_MAX_VISIBLE_CENTROIDS=140
ATTACHMENTS_MVT_PREFETCH_QUEUE_CAP=320
ATTACHMENTS_MVT_PREFETCH_CONCURRENCY=3
ATTACHMENTS_MVT_MAP_LOCK_BOUNDS=false
ATTACHMENTS_MVT_REFRESH_EXPIRED_TILES=false
ATTACHMENTS_MVT_LOG_VERBOSE=false
ATTACHMENTS_MVT_SLOW_TILE_WARN_MS=2000
ATTACHMENTS_MVT_DIAGNOSTIC_LOG_ENABLED=true
ATTACHMENTS_MVT_DIAGNOSTIC_LOG_PATH=
ATTACHMENTS_MVT_USE_PREPROCESSED_MV=true
ATTACHMENTS_PMTILES_ENABLED=false
ATTACHMENTS_PMTILES_BLOB_CONNECTION_STRING=
ATTACHMENTS_PMTILES_BLOB_CONTAINER=
ATTACHMENTS_PMTILES_BLOB_PREFIX=pmtiles

# E2E safety (obrigatorio para npm run test:e2e)
# - TEST_DATABASE_URL deve apontar para um banco com nome final "_test"
# - TEST_DATABASE_HOST_ALLOWLIST deve conter apenas hosts de teste/local
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/landwatch_test?schema=app&sslmode=disable
TEST_DATABASE_HOST_ALLOWLIST=localhost,127.0.0.1

# Fabric / Lakehouse (Fornecedores)
FABRIC_API_BASE_URL=https://api.fabric.microsoft.com
FABRIC_TENANT_ID=
FABRIC_CLIENT_ID=
FABRIC_CLIENT_SECRET=
FABRIC_WORKSPACE_ID=
FABRIC_LAKEHOUSE_ID=
FABRIC_LAKEHOUSE_SQL_CONNECTION_STRING=
FABRIC_LAKEHOUSE_SQL_DATABASE=
FABRIC_LAKEHOUSE_SQL_SCHEMA=dbo
FABRIC_SQL_QUERY_DRIVER=mssql_tedious
FABRIC_CAR_UPDATE_MODE=disabled
FABRIC_CAR_UPDATE_ITEM_ID=
FABRIC_CAR_UPDATE_JOB_TYPE=RunNotebook
FABRIC_CAR_UPDATE_WAIT_SECONDS=60
FABRIC_CAR_UPDATE_POLL_INTERVAL_MS=2000
